---
/**
 * Pagination — prev/next navigation for paginated routes.
 *
 * Only renders when lastPage > 1.
 * Accepts the Astro `page` object from [...page].astro.
 *
 * Used by: posts/[...page].astro
 */

interface PaginationUrls {
  prev?: string;
  next?: string;
}

interface Props {
  currentPage: number;
  lastPage: number;
  url: PaginationUrls;
}

const { currentPage, lastPage, url } = Astro.props;

if (lastPage <= 1) return;
---

<nav class="pagination" aria-label="Pagination">
  {url.prev ? (
    <a href={url.prev} class="pagination__link">← Newer</a>
  ) : (
    <span class="pagination__link pagination__link--disabled" aria-hidden="true">← Newer</span>
  )}

  <span class="pagination__info" aria-label={`Page ${currentPage} of ${lastPage}`}>
    {currentPage} / {lastPage}
  </span>

  {url.next ? (
    <a href={url.next} class="pagination__link">Older →</a>
  ) : (
    <span class="pagination__link pagination__link--disabled" aria-hidden="true">Older →</span>
  )}
</nav>
