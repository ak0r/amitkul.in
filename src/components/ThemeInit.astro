<script is:inline>
  (() => {
    try {
      const stored = localStorage.getItem('theme');
      const dark = stored
        ? stored === 'dark'
        : matchMedia('(prefers-color-scheme: dark)').matches;
      document.documentElement.style.colorScheme = dark ? 'dark' : 'light';
    } catch (_) {}
  })();
</script>
